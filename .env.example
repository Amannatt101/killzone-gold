# =============================================================================
# Deploy on Render (recommended: one Web Service — API + static UI, same origin)
# =============================================================================
# 1. New → Web Service → connect repo (or use Blueprint with render.yaml).
# 2. Build command:  npm install && npm run build
# 3. Start command:    npm start
# 4. Instance type:    Free or Starter (Node 20 — see .node-version).
# 5. Health check path: /api/health
#
# Environment variables on Render (all under the same service):
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY
#   PUBLIC_APP_URL     = https://YOUR-SERVICE.onrender.com  (no trailing slash)
#   APP_AUTH_SECRET    = long random string (JWT signing; do not use the service role key in prod if you can avoid it)
#   VITE_SUPABASE_URL  = same as SUPABASE_URL (required at build time for the client bundle)
#   VITE_SUPABASE_ANON_KEY = Supabase anon key (required at build time)
#
# Leave these EMPTY on Render for same-origin (UI and API on one hostname):
#   VITE_API_BASE_URL=
#   CORS_ORIGINS=
#
# After deploy, open https://YOUR-SERVICE.onrender.com — login and API share one site.

# =============================================================================
# Local / shared
# =============================================================================

# Server-only (never expose to Vite / browser)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT for direct login tokens (defaults to service role key if unset — set a dedicated secret in production)
APP_AUTH_SECRET=

# App URL, no trailing slash (Render: https://your-service.onrender.com)
PUBLIC_APP_URL=http://127.0.0.1:4000

# Only if the browser UI is on a *different* host than this API (e.g. Netlify UI + Render API).
# Comma-separated origins, e.g. CORS_ORIGINS=https://your-site.netlify.app
CORS_ORIGINS=

# Client (Vite) — inlined at build time. On Render, add these to the Web Service env so `npm run build` sees them.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Only when the static app is hosted separately from the API (e.g. Netlify). Otherwise leave empty.
VITE_API_BASE_URL=
